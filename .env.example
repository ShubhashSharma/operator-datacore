# operator-datacore — environment template
# Copy this file to .env and fill in the blanks. Never commit .env.
# Every value here is explained in plain English in SETUP.md.

# ─────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────
# Where: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — full database access. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (used for migrations and admin queries).
# Where: Supabase dashboard → Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=

# ─────────────────────────────────────────────
# Amazon SP-API (required for Amazon sync)
# Each value is explained step-by-step in docs/runbooks/connect-amazon.md
# ─────────────────────────────────────────────
SP_API_LWA_CLIENT_ID=
SP_API_LWA_CLIENT_SECRET=
SP_API_REFRESH_TOKEN=

# Region — the SP-API endpoint to talk to.
# Use: na (US, CA, MX, BR), eu (UK, DE, FR, IT, ES, NL, SE, PL, TR, AE, IN, EG, SA), fe (JP, AU, SG)
SP_API_REGION=na

# Marketplaces — comma-separated list of marketplace IDs you sell on.
# US: ATVPDKIKX0DER, CA: A2EUQ1WTGCTBG2, MX: A1AM78C64UM0Y8, UK: A1F83G8C2ARO7P,
# DE: A1PA6795UKMFR9, FR: A13V1IB3VIYZZH, IT: APJ6JRA9NG5V4, ES: A1RKKUPIHCS9HS,
# JP: A1VC38T7YXB528, AU: A39IBJ37TRP1C6, IN: A21TJRUUN4KGV
SP_API_MARKETPLACE_IDS=ATVPDKIKX0DER

# Optional — only if you've kept legacy SP-API IAM auth alongside LWA.
# Most accounts created after July 2024 don't need these.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SP_API_ROLE_ARN=

# ─────────────────────────────────────────────
# TikTok Shop (homework — leave blank for v1)
# Activate by following docs/runbooks/connect-tiktok.md
# ─────────────────────────────────────────────
# TIKTOK_APP_KEY=
# TIKTOK_APP_SECRET=
# TIKTOK_SHOP_CIPHER=
# TIKTOK_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Shopify (homework — leave blank for v1)
# Activate by following docs/runbooks/connect-shopify.md
# ─────────────────────────────────────────────
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ADMIN_ACCESS_TOKEN=
# SHOPIFY_API_VERSION=2025-04

# ─────────────────────────────────────────────
# Google Workspace (homework — leave blank for v1)
# Activate by following docs/runbooks/connect-google-drive.md
# ─────────────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# GOOGLE_DRIVE_FOLDER_IDS=

# ─────────────────────────────────────────────
# Behaviour
# ─────────────────────────────────────────────
# How many months of history to pull on first run. Configurable per connector.
BACKFILL_MONTHS=24
# Reporting currency for analytics views. Each marketplace stores native currency at row level.
REPORTING_CURRENCY=USD
# Timezone for daily rollups. Default: America/Los_Angeles (Amazon's accounting timezone for US).
ROLLUP_TIMEZONE=America/Los_Angeles
